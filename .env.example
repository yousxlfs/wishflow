# Database (Neon) — Vercel: Storage → Neon → Connect, или vercel env pull
# Pooled URL (hostname с -pooler) — для runtime приложения
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct URL — для локальных миграций (prisma migrate / npm run prisma:migrate)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5 — обязательно на Vercel
# Сгенерировать: openssl rand -hex 32
AUTH_SECRET=""
# Локально:
AUTH_URL="http://localhost:3000"
# На Vercel (Production): https://your-app.vercel.app
# AUTH_URL задаётся автоматически, если подключён домен Vercel

# Google OAuth (опционально, когда подключишь провайдер)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
